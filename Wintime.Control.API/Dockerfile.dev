# Stage 1: Build Vue frontend
FROM node:20-alpine AS frontend-build
WORKDIR /web
COPY Wintime-Control-Frontend/package*.json ./
RUN npm ci
COPY Wintime-Control-Frontend/ ./
RUN npm run build

# Stage 2: Build .NET app
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY ["Wintime.Control.API/Wintime.Control.API.csproj", "Wintime.Control.API/"]
COPY ["Wintime.Control.Core/Wintime.Control.Core.csproj", "Wintime.Control.Core/"]
COPY ["Wintime.Control.Infrastructure/Wintime.Control.Infrastructure.csproj", "Wintime.Control.Infrastructure/"]
COPY ["Wintime.Control.Shared/Wintime.Control.Shared.csproj", "Wintime.Control.Shared/"]

RUN dotnet restore "Wintime.Control.API/Wintime.Control.API.csproj" /p:SkipFrontendBuild=true

COPY . .
COPY --from=frontend-build /Wintime.Control.API/wwwroot Wintime.Control.API/wwwroot/

WORKDIR "/src/Wintime.Control.API"
RUN dotnet publish "Wintime.Control.API.csproj" -c Release -o /app/publish /p:UseAppHost=false /p:SkipFrontendBuild=true

# Stage 3: Runtime
FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime
WORKDIR /app
USER app
COPY --from=build --chown=app:app /app/publish .
EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080
ENV ASPNETCORE_ENVIRONMENT=Production
ENTRYPOINT ["dotnet", "Wintime.Control.API.dll"]
