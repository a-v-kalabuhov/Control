# Wintime Control — пилотный деплой (ПЗП). Заполнить и сохранить как ".env".
# Пароль PostgreSQL (любая надёжная строка)
DB_PASSWORD=change-me-db
# Пароль первого администратора (логин: admin). ОБЯЗАТЕЛЬНО заменить.
# ТРЕБОВАНИЯ (иначе админ НЕ создастся и войти не получится): минимум 8 символов,
# минимум одна заглавная, одна строчная, одна цифра и один спецсимвол (напр. - _ ! @).
# Значение ниже НАМЕРЕННО не проходит политику: если забыть заменить — админа не будет
# (вход закрыт), а не пустит с известным паролем.
BOOTSTRAP_ADMIN_PASSWORD=REPLACE_ME
# Пароль PFX-сертификата. У mkcert по умолчанию — changeit (не менять без нужды)
CERT_PASSWORD=changeit
# Для пилота — false (http-дашборды + https-планшеты). НЕ менять.
HTTPS_REDIRECT=false
